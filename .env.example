# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/luxe-interiors

# Authentication
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# Admin credentials (initial setup)
ADMIN_EMAIL=admin@luxeinteriors.com
ADMIN_PASSWORD=your_secure_password

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Luxe Interiors <noreply@luxeinteriors.com>

# App URL
NEXT_PUBLIC_APP_URL=https://luxeinteriors.com

# Instagram (optional)
INSTAGRAM_ACCESS_TOKEN=your_instagram_token
INSTAGRAM_USER_ID=your_instagram_user_id

# OpenAI (for AI Room Visualizer)
OPENAI_API_KEY=sk-...
